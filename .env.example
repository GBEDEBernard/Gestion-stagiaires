APP_NAME=Gestion-stagiaires
APP_ENV=production
APP_KEY=base64:9mkVem7/Xvy1LG3kDfOQee0Ki9dygryjfeOI5nnxZNI=
APP_DEBUG=false
APP_URL=https://gestion-stagiaires.up.railway.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=xixPfeaXiRYctcWPkIKGcnuyfamHohpV

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_EXPIRE_ON_CLOSE=true

# Temps réel : 'log' = désactivé (le chat des tâches utilise le polling).
# Mettre 'reverb' + lancer `php artisan reverb:start` pour activer le WebSocket.
BROADCAST_CONNECTION=log
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=gestion_stagiaire

# --- Laravel Reverb (temps réel WebSocket, optionnel) ---
# 1) BROADCAST_CONNECTION=reverb + BROADCAST_DRIVER=reverb
# 2) VITE_REVERB_APP_KEY="${REVERB_APP_KEY}" (laisser vide = polling)
# 3) `php artisan reverb:start` puis `npm run build`
# Choisir un REVERB_SERVER_PORT libre (8080 souvent déjà pris sous Windows).
REVERB_APP_ID=gestion-stagiaires
REVERB_APP_KEY=gestion-stagiaires-key
REVERB_APP_SECRET=gestion-stagiaires-secret
REVERB_HOST=localhost
REVERB_PORT=9090
REVERB_SCHEME=http
REVERB_SERVER_PORT=9090
REVERB_SERVER_HOST=0.0.0.0

# Côté front (Vite inline ces valeurs au build) — vide = polling, sinon temps réel.
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
